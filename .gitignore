# Keel - Root Gitignore
# Covers Next.js (Frontend), FastAPI (Backend), IDEs, and OS temp files

# Node / Frontend
node_modules/
.next/
out/
.vercel
next-env.d.ts
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python / Backend
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
.venv/
venv/
ENV/
env/

# Testing, Linting & Coverage
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.mypy_cache/

# Local configuration and environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.pem

# Editor / IDE settings
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# OS metadata
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# SQLite database
*.db

# Agent & CLI caches
.entire/logs/
.entire/metadata.json
.antigravitycli/

